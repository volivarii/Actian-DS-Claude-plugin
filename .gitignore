# OS
.DS_Store

# Claude Code local session files
.claude/
settings.json

# Generated output (teammates create their own via skills)
# Anchored to repo root so they don't accidentally match nested
# directories like plugins/*/vendor/components/.
/components/
/flows/
/presentations/
/prototypes/

# Annotation files (browser preview artifacts)
.annotations.json

# Test files (local dev artifacts)
test-*.html

# Python
*.pyc
__pycache__/

# Node
node_modules/

# Figma file keys (sensitive — create from .figma-keys.json.example)
plugins/*/.figma-keys.json

# Secrets / API tokens (Figma PAT, etc.) — create from .env.example
.env
.env.local
plugins/*/.env
plugins/*/.env.local

# Test prompts (local reference only)
plugins/*/TEST-PROMPTS.md

# Evals: ignore workspace outputs (regenerated per run) and stray transcripts,
# but track eval lane definitions (fixtures, evals.json, grader.md, README.md)
plugins/actian-design-system/evals/**/workspace/
plugins/actian-design-system/evals/**/*.transcript.json

# Release notes (local drafts for Slack)
release-notes/

# Token drift reports (informational, generated by /sync-design-system)
token-drift.json

# Superpowers working files (plans, specs, audits) — never tracked
# Globstar so this catches both repo-root docs/superpowers/ AND nested
# plugins/*/docs/superpowers/ paths.
**/docs/superpowers/
**/.superpowers/

# Root-level scratch docs
/docs/

# Communication
comms/


# Demo flow rendered deliverables (regenerable; embed ~340kb fonts)
demo-flows/*.html
demo-flows/*.flow.json
