        "heading": "Usage",
        "content": [
          { "rule": "Use when a page or drawer contains primary actions that must remain available during scrolling." },
          { "rule": "Use when users complete steppers or multi-field forms." },
          { "rule": "Use when the action affects entire page/drawer/form state." }
