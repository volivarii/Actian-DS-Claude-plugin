      {
        "heading": "Button hierarchy",
        "content": [
          { "rule": "Must contain exactly one primary action." },
          { "rule": "Exception: additional destructive button (Delete)." },
          { "rule": "Optional secondary action." },
          { "rule": "Max 3 buttons." }
        ]
      },
      {
        "heading": "Button labels",
        "content": [
          { "rule": "Use clear verbs describing the OUTCOME: Save, Update, Create, Confirm, Submit, Cancel, Delete, Continue." },
          { "rule": "Avoid generic labels like 'Done'." }
        ]
      },
      {
        "heading": "Steppers",
        "content": [
          { "rule": "Label terminology: Back, Next, Submit (final step)." },
          { "rule": "Do not mix: Continue and Next, Finish and Submit." }
        ]
      }
