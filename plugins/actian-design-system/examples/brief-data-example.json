  "card6_usage": {
    "whenToUse": [
      "Navigation to internal or external destinations (pages, sections, resources)",
      "Inline contextual navigation within body text or descriptions",
      "Standalone navigation elements like breadcrumbs or footer links"
    ],
    "whenNotToUse": [
      "Actions that don't navigate (submit, delete, toggle) → use Button",
      "Primary call-to-action → use Button with appropriate hierarchy",
      "Standalone icons as navigation → use Icon Button instead"
    ],
    "doDont": [
      {
        "doLabel": "Use for navigation",
        "doDetail": "Links should always navigate to a destination — a new page, section, or external resource.",
        "dontLabel": "Use for actions",
        "dontDetail": "Don't use links for actions like submitting a form or deleting an item. Use ghost buttons instead."
      },
      {
        "doLabel": "Use descriptive text",
        "doDetail": "Link text should describe the destination clearly, e.g., 'View pipeline details'.",
        "dontLabel": "Use vague text",
        "dontDetail": "Avoid generic labels like 'Click here', 'Read more', or raw URLs as link text."
      },
      {
        "doLabel": "Indicate external links",
        "doDetail": "Add a trailing icon or label when the link opens in a new tab or goes to an external site.",
        "dontLabel": "Surprise navigation",
        "dontDetail": "Don't open links in new tabs without visual indication — users should anticipate the behavior."
      }
    ]
  },
  "card7_content": {
    "rules": [
      {
        "title": "Use clear and descriptive link text",
        "description": "Link text should describe the destination or action. Avoid generic phrases that require surrounding context to understand.",
        "do": "View your order details",
        "dont": "Click here"
      },
      {
        "title": "Use action-oriented language",
        "description": "For links that lead to tasks, use precise action verbs. This is especially important for links for actions like downloads.",
        "do": "Download report",
        "dont": "Get report"
      },
      {
        "title": "Use sentence case",
        "description": "Capitalize only the first word and proper nouns. Always provide clarity on what will happen when the user clicks.",
        "do": "Explore features",
        "dont": "Click to learn more"
      },
      {
        "title": "Keep link text concise",
        "description": "A navigational element's text should be short enough to provide clarity on what it does. Should be meaningful but not wordy.",
        "do": "View our services",
        "dont": "Click here to view our list of services"
      },
      {
        "title": "Avoid linking full sentences or paragraphs",
        "description": "Link only the specific actionable words, not entire sentences. Avoid formatting entire sentences as clickable links to improve readability.",
        "do": "Read our user experience design blog",
        "dont": "Click here to read our blog about user experience design"
      },
      {
        "title": "Consistency in link text",
        "description": "Use consistent phrasing for similar link actions. Inline labels should use the same terminology to \"Read more\" destinations, not switch between \"See more\", \"Learn more\", etc.",
        "do": "View our services",
        "dont": "Click here to view our list of services"
      }
    ],
    "terminology": [
      {
        "term": "Link",
        "use": "A navigational element that takes the user to a new destination"
      },
      {
        "term": "Button",
        "use": "An action trigger — use when the click performs an action rather than navigating"
      }
    ]
  },
  "card8_accessibility": {
    "requirements": [
      {
        "title": "Default state: underlined",
        "icon": "blue",
        "body": "Standard practice is to underline links in their default state. This ensures the link is distinguishable from surrounding text by a visual cue other than color alone.",
        "code": {
          "language": "css",
          "tokens": [
            {
              "type": "selector",
              "text": "a"
            },
            {
              "type": "punctuation",
              "text": " { "
            },
            {
              "type": "property",
              "text": "text-decoration"
            },
            {
              "type": "punctuation",
              "text": ": "
            },
            {
              "type": "value",
              "text": "underline"
            },
            {
              "type": "punctuation",
              "text": "; }"
            }
          ]
        }
      },
      {
        "title": "Non-underlined link contrast",
        "icon": "red",
        "body": "When links are not underlined by default, they must have at least 3:1 contrast ratio against surrounding body text, and 4.5:1 against background. A non-color indicator must appear on hover/focus.",
        "code": {
          "language": "html",
          "tokens": [
            {
              "type": "comment",
              "text": "/* 3:1 vs body text */"
            },
            {
              "type": "newline"
            },
            {
              "type": "comment",
              "text": "/* 4.5:1 vs background */"
            }
          ]
        }
      },
      {
        "title": "Focus indication",
        "icon": "blue",
        "body": "Links must have a visible focus indicator when navigated via keyboard. Use a 2px outline with 2px offset in the theme-primary color.",
        "code": {
          "language": "css",
          "tokens": [
            {
              "type": "selector",
              "text": "a:focus-visible"
            },
            {
              "type": "punctuation",
              "text": " { "
            },
            {
              "type": "property",
              "text": "outline"
            },
            {
              "type": "punctuation",
              "text": ": "
            },
            {
              "type": "value",
              "text": "2px solid var(--theme-primary)"
            },
            {
              "type": "punctuation",
              "text": "; "
            },
            {
              "type": "property",
              "text": "outline-offset"
            },
            {
              "type": "punctuation",
              "text": ": "
            },
            {
              "type": "value",
              "text": "2px"
            },
            {
              "type": "punctuation",
              "text": "; }"
            }
          ]
        }
      },
      {
        "title": "Semantic HTML",
        "icon": "green",
        "body": "Always use the native <a> element with a valid href attribute. Never use <span> or <div> styled as a link. The href ensures proper keyboard navigation and screen reader announcements.",
        "code": {
          "language": "html",
          "tokens": [
            {
              "type": "tag",
              "text": "<a"
