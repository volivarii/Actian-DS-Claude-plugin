{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "brief-data.schema.json",
  "title": "Brief Data",
  "description": "Schema for brief-data.json consumed by brief-to-figma.js",
  "type": "object",
  "required": ["meta", "card_header"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["fm", "ds"],
      "description": "Brief mode - inferred from meta.library if missing"
    },
    "meta": {
      "type": "object",
      "description": "Generation metadata",
      "required": ["component", "skill"],
      "properties": {
        "component": {
          "type": "string",
          "description": "Component display name"
        },
        "library": {
          "type": "string",
          "description": "Source library (fm or dsKit)"
        },
        "fileKey": {
          "type": "string",
          "description": "Figma file key"
        },
        "nodeId": {
          "type": "string",
          "description": "Figma node ID"
        },
        "componentKey": {
          "type": "string",
          "description": "Figma component key"
        },
        "generatedAt": {
          "type": "string",
          "description": "ISO 8601 generation timestamp"
        },
        "skill": {
          "type": "string",
          "const": "component-brief",
          "description": "Skill identifier"
        },
        "pluginVersion": {
          "type": "string",
          "description": "Plugin version at generation time"
        },
        "model": {
          "type": "string",
          "description": "AI model used for generation"
        },
        "duration": {
          "type": "string",
          "description": "Generation duration"
        }
      }
    },
    "card_header": {
      "type": "object",
      "description": "Page header card (DS mode)",
      "required": ["name", "description"],
      "properties": {
        "source": {
          "type": "string",
          "description": "Kit identifier (FM mode)"
        },
        "name": {
          "type": "string",
          "description": "Component display name"
        },
        "description": {
          "type": "string",
          "description": "1-3 sentence component description"
        }
      }
    },
    "card_component": {
      "type": "object",
      "description": "Component variants and theme comparison",
      "properties": {
        "variantAxes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "axis": { "type": "string" },
              "values": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "variantMatrix": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "row": { "type": "string" },
              "columns": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": { "type": "string" },
                    "variantName": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "gridColumns": {
          "type": ["number", "integer"],
          "description": "Grid columns for FM mode variant display"
        },
        "variants": {
          "type": "array",
          "description": "Flat variant list for FM mode",
          "items": {
            "type": "object",
            "properties": {
              "variantName": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        },
        "themeComparison": {
          "type": "object",
          "description": "Theme comparison swatches",
          "properties": {
            "actian": { "$ref": "#/$defs/themeEntry" },
            "studio": { "$ref": "#/$defs/themeEntry" },
            "explorer": { "$ref": "#/$defs/themeEntry" }
          }
        }
      }
    },
    "card_anatomy": {
      "type": "object",
      "description": "Anatomy card (DS mode)",
      "properties": {
        "parts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "letter": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "figmaLayerName": { "type": "string" }
            }
          }
        },
        "specs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "orientation": {
                "type": "string",
                "enum": ["vertical", "horizontal"]
              },
              "target": { "type": "string" }
            }
          }
        },
        "states": {
          "type": "array",
          "items": { "type": "string" }
        },
        "partsTable": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "part": { "type": "string" },
              "element": { "type": "string" },
              "token": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        }
      }
    },
    "card3_design_guidelines": {
      "type": "object",
      "description": "Design guidelines card (FM mode)",
      "properties": {
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "body": { "type": "string" }
            }
          }
        }
      }
    },
    "card_tokens": {
      "type": "object",
      "description": "Design tokens card (DS mode)",
      "properties": {
        "colorTokens": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "state": { "type": "string" },
              "columns": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "header": { "type": "string" },
                    "token": { "type": "string" },
                    "hex": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "sizingTokens": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "property": { "type": "string" },
              "token": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "typography": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "element": { "type": "string" },
              "token": { "type": "string" },
              "font": { "type": "string" },
              "tracking": { "type": "string" }
            }
          }
        }
      }
    },
    "card4_content_guidelines": {
      "type": "object",
      "description": "Content guidelines card (FM mode)",
      "properties": {
        "whenToUse": {
          "type": "string",
          "description": "Paragraph describing when to use"
        },
        "doDont": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "do": { "type": "string" },
              "dont": { "type": "string" }
            }
          }
        }
      }
    },
    "card5_api": {
      "type": "object",
      "description": "Component API card (DS mode — retired, use card_api is forbidden)",
      "deprecated": true,
      "properties": {
        "props": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "required": { "type": "boolean" },
              "name": { "type": "string" },
              "type": { "type": "string" },
              "default": { "type": "string" },
              "values": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        }
      }
    },
    "card5_anatomy": {
      "type": "object",
      "description": "Anatomy card (FM mode)",
      "properties": {
        "parts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "number": { "type": ["number", "integer"] },
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "card_usage": {
      "type": "object",
      "description": "Usage guidelines card (DS mode)",
      "properties": {
        "whenToUse": {
          "type": "array",
          "items": { "type": "string" }
        },
        "whenNotToUse": {
          "type": "array",
          "items": { "type": "string" }
        },
        "doDont": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "doLabel": { "type": "string" },
              "doDetail": { "type": "string" },
              "dontLabel": { "type": "string" },
              "dontDetail": { "type": "string" }
            }
          }
        }
      }
    },
    "card_content": {
      "type": "object",
      "description": "Content guidelines card (DS mode)",
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "do": { "type": "string" },
              "dont": { "type": "string" },
              "doExample": {
                "type": "string",
                "description": "Concrete example showing the Do guideline"
              },
              "dontExample": {
                "type": "string",
                "description": "Concrete example showing the Don't guideline"
              }
            }
          }
        },
        "terminology": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "term": { "type": "string" },
              "use": { "type": "string" }
            }
          }
        }
      }
    },
    "card_accessibility": {
      "type": "object",
      "description": "Accessibility card (DS mode)",
      "properties": {
        "requirements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "icon": { "type": "string" },
              "body": { "type": "string" },
              "code": {
                "type": "object",
                "properties": {
                  "language": { "type": "string" },
                  "tokens": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": { "type": "string" },
                        "text": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "contrastTable": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "element": { "type": "string" },
              "foreground": { "type": "string" },
              "background": { "type": "string" },
              "ratio": { "type": "string" },
              "wcag": { "type": "string" }
            }
          }
        },
        "ariaTable": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "element": { "type": "string" },
              "role": { "type": "string" },
              "label": { "type": "string" },
              "focusOrder": { "type": "string" },
              "keyboard": { "type": "string" },
              "announcement": { "type": "string" }
            }
          }
        }
      }
    },
    "card_motion": {
      "type": "object",
      "description": "Behavior & motion card (DS mode) — conditional. Only present when the component has a curated motion pattern (component-guidelines/<slug>.json behavior.motion.pattern is set). Pattern data is sourced from docs/generated/foundations/interaction-motion.json.",
      "properties": {
        "_source": {
          "type": "string",
          "enum": ["figma", "generated", "scaffold"]
        },
        "patternSlug": {
          "type": "string",
          "description": "Slug into foundations interaction-motion.json#patterns, e.g. 'drawer', 'modal', 'success-toast'"
        },
        "patternName": {
          "type": "string",
          "description": "Human-readable name (e.g. 'Drawer (open/close)')"
        },
        "phases": {
          "type": "array",
          "description": "Phase rows from the canonical motion pattern (Phase / Duration / Easing / Behavior, or pattern-specific columns)",
          "items": { "type": "object" }
        },
        "logic_and_accessibility": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "overrides": {
          "type": "string",
          "description": "Optional component-specific deviations from the canonical pattern (free-text)"
        }
      }
    },
    "card9_code": {
      "type": "object",
      "description": "Code specification card (DS mode — retired)",
      "deprecated": true,
      "properties": {
        "language": {
          "type": "string",
          "description": "Programming language"
        },
        "tokens": {
          "type": "array",
          "description": "Syntax-highlighted token array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "themeEntry": {
      "type": "object",
      "description": "Theme comparison entry",
      "properties": {
        "variantName": { "type": "string" },
        "swatches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "token": { "type": "string" },
              "hex": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
