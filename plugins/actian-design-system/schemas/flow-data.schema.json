{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flow-data.schema.json",
  "title": "Flow Data",
  "description": "Schema for flow-data.json consumed by flow-to-figma.js",
  "type": "object",
  "required": ["meta", "screens"],
  "properties": {
    "meta": {
      "type": "object",
      "description": "Generation metadata and flow context",
      "required": ["feature"],
      "properties": {
        "feature": {
          "type": "string",
          "description": "Feature name - used for cover card and wrapper name"
        },
        "flow": {
          "type": "string",
          "description": "Flow description for cover card"
        },
        "user": {
          "type": "string",
          "description": "User role for cover card"
        },
        "app": {
          "type": "string",
          "enum": ["Studio", "Explorer", "Administration", "Actian"],
          "description": "Application context - sets App Header variant"
        },
        "targetNodeId": {
          "type": "string",
          "description": "Figma node ID for placement"
        },
        "prompt": {
          "type": "string",
          "description": "Original prompt for Generation Log"
        },
        "duration": {
          "type": "string",
          "description": "Generation duration for Generation Log"
        },
        "model": {
          "type": "string",
          "description": "AI model used for generation"
        },
        "pluginVersion": {
          "type": "string",
          "description": "Plugin version at generation time"
        },
        "skill": {
          "type": "string",
          "const": "generate-flow",
          "description": "Skill identifier"
        },
        "mode": {
          "type": "string",
          "enum": ["full", "refine"],
          "description": "How the artifact was produced. 'full' (default) is generation-from-scratch; 'refine' indicates a partial patch over a prior push. Drives downstream gate behavior alongside the runtime --scope flag."
        },
        "research": {
          "type": "object",
          "description": "Optional research findings - triggers Research Frame card",
          "properties": {
            "title": {
              "type": "string",
              "description": "Research card title (default: UX Research)"
            },
            "source": {
              "type": "string",
              "description": "Source attribution"
            },
            "competitors": {
              "type": "string",
              "description": "How competitors handle this"
            },
            "patterns": {
              "type": "string",
              "description": "Key patterns adopted"
            },
            "recommendation": {
              "type": "string",
              "description": "Summary recommendation"
            },
            "sources": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Source list - URLs or product names"
            }
          }
        },
        "variants": {
          "type": "object",
          "description": "Sprint A surface flag --variants payload. Records the requested variant count and per-variant provenance so /compare-flows can diff between variants. Engine consumption deferred to Sprint B+.",
          "properties": {
            "count": {
              "type": ["number", "integer"],
              "minimum": 1,
              "maximum": 5,
              "description": "Number of structurally-distinct variants requested (1 = single output, 2-5 = multi-variant)"
            },
            "index": {
              "type": ["number", "integer"],
              "minimum": 0,
              "description": "Zero-based index of THIS variant within the set"
            },
            "label": {
              "type": "string",
              "description": "Human-readable label for the variant (e.g. 'detail-page', 'split-view')"
            },
            "siblingIds": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Figma node IDs of sibling variants for /compare-flows lookup"
            }
          }
        },
        "references": {
          "type": "array",
          "description": "Sprint A surface flag --ref payload. Reference URLs whose structural fingerprint should bias recipe selection. v1: Figma URLs only. Engine consumption (vision pipeline) deferred to Sprint C.",
          "items": {
            "type": "object",
            "required": ["url"],
            "properties": {
              "url": {
                "type": "string",
                "description": "Reference URL (Figma in v1; image URLs deferred to v2)"
              },
              "kind": {
                "type": "string",
                "enum": ["figma-frame", "figma-file", "image", "spec"],
                "description": "URL classification"
              },
              "weight": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Optional blending weight for multi-reference inputs"
              }
            }
          }
        },
        "breakpoints": {
          "type": "array",
          "description": "Sprint A surface flag --breakpoints payload. Breakpoints to generate variants for. Lo-fi level = structural decisions only (collapse, stack).",
          "items": {
            "type": "string",
            "description": "Breakpoint name: 'tablet', 'mobile', or 'custom-Npx' (e.g. 'custom-1024px')"
          }
        },
        "branch": {
          "type": "object",
          "description": "Sprint A surface flag --branch payload. Provenance for forks created via --from <url> --branch <name>.",
          "properties": {
            "name": {
              "type": "string",
              "description": "Branch label (forms the suffix on the forked frame name)"
            },
            "fromUrl": {
              "type": "string",
              "description": "Source Figma URL the branch was forked from"
            },
            "fromNodeId": {
              "type": "string",
              "description": "Source node ID resolved from fromUrl"
            }
          }
        },
        "states": {
          "type": "array",
          "description": "Sprint A surface flag --states payload. Coverage states to generate as additional screens or variants.",
          "items": {
            "type": "string",
            "enum": [
              "empty",
              "error",
              "loading",
              "no-permission",
              "populated",
              "partial-data"
            ]
          }
        },
        "_glossary": {
          "type": "object",
          "description": "Shared vocabulary for cross-screen terminology consistency. Built by generate-flow after Gate 3, consumed by screen-generator agents.",
          "properties": {
            "entity": {
              "type": "string",
              "description": "Singular entity name (e.g., 'Data Product')"
            },
            "entityPlural": {
              "type": "string",
              "description": "Plural form (e.g., 'Data Products')"
            },
            "entityLower": {
              "type": "string",
              "description": "Lowercase singular (e.g., 'data product')"
            },
            "entityPluralLower": {
              "type": "string",
              "description": "Lowercase plural (e.g., 'data products')"
            },
            "createVerb": {
              "type": "string",
              "description": "Verb for creation CTAs (e.g., 'Create')"
            },
            "editVerb": {
              "type": "string",
              "description": "Verb for edit CTAs (e.g., 'Edit')"
            },
            "deleteVerb": {
              "type": "string",
              "description": "Verb for delete CTAs (e.g., 'Delete')"
            },
            "primaryCTA": {
              "type": "string",
              "description": "Main action label (e.g., 'Create data product')"
            },
            "pageTitle": {
              "type": "string",
              "description": "Default page title (e.g., 'Data Products')"
            },
            "sidebarActive": {
              "type": "string",
              "description": "Active sidebar item (e.g., 'Catalog')"
            },
            "app": {
              "type": "string",
              "description": "App name (e.g., 'Studio')"
            },
            "entityProperties": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Standard field names for this entity from app-context.json"
            }
          }
        }
      }
    },
    "screens": {
      "type": "array",
      "description": "Array of screen definitions",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "content"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Stable kebab-case identifier. Used by `pushedNodes[].screenId` linking and refine resolution. Auto-derived as <feature-slug>-<index> when omitted (validate-time stamp). Always optional in schema; always present after validate()."
          },
          "name": {
            "type": "string",
            "description": "Screen name (e.g. Screen 1: Dashboard)"
          },
          "template": {
            "type": "string",
            "description": "Template name controlling chrome, size, layout"
          },
          "chrome": {
            "type": "string",
            "description": "Legacy chrome field (deprecated - use template)",
            "deprecated": true
          },
          "size": {
            "type": "string",
            "description": "Legacy size field (deprecated - use template)",
            "deprecated": true
          },
          "activeNavItem": {
            "type": "string",
            "description": "Label for the active sidebar nav item"
          },
          "navItems": {
            "type": ["number", "integer"],
            "description": "Number of sidebar nav items"
          },
          "pageHeader": {
            "type": "object",
            "description": "Page header configuration",
            "properties": {
              "title": { "type": "string" },
              "subtitle": { "type": "string" },
              "actions": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "contentSpacing": {
            "type": ["number", "integer"],
            "description": "Vertical spacing (px) between content items"
          },
          "width": {
            "type": ["number", "integer"],
            "description": "Override width (for custom template)"
          },
          "height": {
            "type": ["number", "integer"],
            "description": "Override height (for custom template)"
          },
          "content": {
            "type": "array",
            "description": "Array of content nodes",
            "items": { "$ref": "#/$defs/contentNode" }
          },
          "contentHtml": {
            "type": "string",
            "description": "Legacy HTML content (deprecated - use content[])",
            "deprecated": true
          },
          "tier": {
            "type": "string",
            "enum": ["recognized", "adapted", "improvised"],
            "description": "Classifier output: how strictly does this screen follow recipes?"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Classifier confidence in the tier assignment"
          },
          "matchedRecipe": {
            "type": ["string", "null"],
            "description": "Recipe ID matched at tier 1; at tier 2 (deviation sub-case) the deviated-from recipe ID; null when tier 2 is a composition or tier 3"
          },
          "composition": {
            "type": ["array", "null"],
            "items": { "type": "string" },
            "description": "Recipe IDs composed at tier 2; null otherwise"
          },
          "justification": {
            "type": ["string", "null"],
            "minLength": 30,
            "description": "Required for tier 2 and 3; explains deviation or invention"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "tier": { "const": "improvised" } },
              "required": ["tier"]
            },
            "then": { "required": ["justification"] }
          },
          {
            "if": {
              "properties": { "tier": { "const": "adapted" } },
              "required": ["tier"]
            },
            "then": { "required": ["justification"] }
          }
        ]
      }
    }
  },
  "$defs": {
    "contentNode": {
      "type": "object",
      "description": "Recursive content node for screen content",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["FRAME", "TEXT", "INSTANCE", "DIVIDER", "ELLIPSE", "RECT"],
          "description": "Node type"
        },
        "name": {
          "type": "string",
          "description": "Node name for Figma layer"
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/contentNode" },
          "description": "Child nodes (for FRAME type)"
        },
        "content": {
          "type": "string",
          "description": "Text content (for TEXT type)"
        },
        "ref": {
          "type": "string",
          "description": "FM component reference (for INSTANCE type)"
        },
        "variant": {
          "type": "string",
          "description": "Variant string (for INSTANCE type)"
        },
        "props": {
          "type": "object",
          "description": "Component properties (for INSTANCE type)"
        },
        "layout": {
          "type": "object",
          "description": "Auto-layout configuration"
        },
        "sizing": {
          "type": "object",
          "description": "Sizing constraints"
        },
        "fills": {
          "type": "array",
          "description": "Fill colors"
        },
        "stroke": {
          "type": "object",
          "description": "Stroke configuration"
        },
        "cornerRadius": {
          "description": "Corner radius (number or per-corner object)"
        },
        "font": {
          "type": "string",
          "description": "Font family:weight (for TEXT type)"
        },
        "size": {
          "type": ["number", "integer"],
          "description": "Font size (for TEXT type)"
        },
        "color": {
          "type": "string",
          "description": "Text color hex (for TEXT type)"
        },
        "opacity": {
          "type": "number",
          "description": "Node opacity (0-1)"
        },
        "width": {
          "type": ["number", "integer"],
          "description": "Explicit width"
        },
        "height": {
          "type": ["number", "integer"],
          "description": "Explicit height"
        },
        "letterSpacing": {
          "type": "object",
          "description": "Letter spacing configuration"
        },
        "intent": {
          "type": "string",
          "enum": [
            "destructive-action",
            "success-confirmation",
            "error-state",
            "default"
          ],
          "description": "Semantic intent for variant selection in hifi conversion. Optional. Inherited by descendants unless overridden at a leaf."
        }
      }
    }
  }
}
